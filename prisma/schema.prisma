enum EscrowStatus {
  CREATED
  PAYING
  HELD
  PARTIAL_RELEASE
  FULL_RELEASE
  CLOSED
  REFUND
  DISPUTE
}

enum PaymentCollectionStatus {
  UNPAID
  PAID
  FAILED
  CANCELLED
}

enum CreatorPayoutStatus {
  MANUAL_PAYOUT_PENDING
  PAID
}

enum TransactionType {
  ESCROW_DEPOSIT
  ESCROW_RELEASE
  PLATFORM_COMMISSION
  CLIENT_SERVICE_FEE
  MEMBERSHIP_FEE
  WITHDRAW_REQUEST
  WITHDRAW_SUCCESS
  WITHDRAW_FAILED
  REFUND
  CHARGEBACK
  BONUS
  PENALTY
  DISPUTE_FREEZE
  DISPUTE_RELEASE
}

enum WalletAccountStatus {
  ACTIVE
  SUSPENDED
  CLOSED
}

enum WalletAssetCode {
  USD
  CNY
  EUR
  USDT
  USDC
  BTC
  ETH
  TRX
}

enum PaymentChannel {
  STRIPE
  PAYPAL
  WISE
  BANK_TRANSFER
  ALIPAY
  WECHAT_PAY
  ABA_LOCAL_BANK
  MANUAL_OFFLINE
  CRYPTO_ONCHAIN
