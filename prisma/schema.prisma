enum PaymentMethodProvider {
  STRIPE
  PAYPAL
  WISE
  BANK_TRANSFER
  ALIPAY
  WECHAT_PAY
  ABA_LOCAL_BANK
  MANUAL_OFFLINE
  CRYPTO
}

enum PaymentMethodStatus {
  PENDING
  VERIFIED
  DISABLED
