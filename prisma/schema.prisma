  PROCESSING
  SUCCESS
  FAILED
  RETRY
  DEAD_LETTER
}

enum DisputeStatus {
  OPEN
  PROCESSING
  RESOLVED
  CLOSED
}

enum CreatorMembershipPlanType {
  DEFAULT
  VERIFIED
}

enum CreatorMembershipStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  REFUNDED
}

enum CreatorMembershipPaymentProvider {
  STRIPE
  PAYPAL
  CRYPTO
  ADMIN
  DEMO
}

enum CreatorMembershipHistoryAction {
  CREATED
  ACTIVATED
  RENEWED
  EXPIRED
  DOWNGRADED
  CANCELLED
  REFUNDED
  ADMIN_UPGRADE
  ADMIN_DOWNGRADE
  ADMIN_EXTEND
  UPGRADE_DECLINED
}

// ─── Users ───────────────────────────────────────────────────────────────────

model User {
  id            String     @id @default(uuid())
  email         String     @unique
  passwordHash  String?    @map("password_hash")
  role          UserRole
  status        UserStatus @default(ACTIVE)
  avatarUrl     String?    @map("avatar_url")
  fullName      String     @map("full_name")
  nickname      String?
  phone         String?    @unique
  country       String?
  timezone      String?
  language      String?    @default("en")
  languageCode  String     @default("en") @map("language_code")
  emailVerified Boolean    @default(false) @map("email_verified")
  lastLoginAt   DateTime?  @map("last_login_at")
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")
  deletedAt     DateTime?  @map("deleted_at")

  brandProfile   BrandProfile?
  creatorProfile CreatorProfile?
  studioProfile  StudioProfile?
  brandCampaigns Campaign[]      @relation("BrandCampaigns")
  creatorCampaigns Campaign[]    @relation("CreatorCampaigns")
  clientOrders     Order[]       @relation("ClientOrders")
  creatorOrders    Order[]       @relation("CreatorOrders")
  referredOrders   Order[]       @relation("ReferredOrders")
  reviewComments ReviewComment[]
  activityLogs   ActivityLog[]
  notifications  Notification[]
  performanceSources PerformanceSource[]
  wallet         Wallet?
  walletAccount  WalletAccount?
  paymentMethods PaymentMethod[]
  sentMessages     CommunicationMessage[] @relation("SentMessages")
  receivedMessages CommunicationMessage[] @relation("ReceivedMessages")
  aiPreference     AiPreference?
  brandRelationships    RelationshipDna[] @relation("BrandRelationships")
  creatorRelationships  RelationshipDna[] @relation("CreatorRelationships")
  creatorMemberships    CreatorMembership[]
  creatorEarnings       CreatorEarnings?
  orderCommissions      OrderCommission[] @relation("CreatorOrderCommissions")
  membershipHistory     CreatorMembershipHistory[] @relation("CreatorMembershipHistory")
  referralCodes         ReferralCode[]
  referralsMade         ReferralRelation[] @relation("ReferralsMade")
  referralsReceived     ReferralRelation[] @relation("ReferralsReceived")
  referralCommissions   ReferralCommission[] @relation("ReferralCommissions")
  storageFiles          StorageFile[]
  customerConversations Conversation[] @relation("CustomerConversations")
  assignedConversations Conversation[] @relation("AssignedConversations")
  preferredLanguage Language @relation(fields: [languageCode], references: [code])

  @@index([role])
  @@index([status])
  @@index([phone])
  @@index([languageCode])
  @@map("users")
}

model Language {
  id          String   @id @default(uuid())
  code        String   @unique
  locale      String   @unique
  nativeName  String   @map("native_name")
  englishName String   @map("english_name")
  isDefault   Boolean  @default(false) @map("is_default")
  isEnabled   Boolean  @default(true) @map("is_enabled")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  users        User[]
  translations LanguageTranslation[]

  @@index([isEnabled, sortOrder])
  @@map("languages")
}

model LanguageKey {
  id          String   @id @default(uuid())
  namespace   String
  key         String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  translations LanguageTranslation[]

  @@unique([namespace, key])
  @@index([namespace])
  @@map("language_keys")
}

model LanguageTranslation {
  id         String   @id @default(uuid())
  keyId      String   @map("key_id")
  languageCode String @map("language_code")
  value      String
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  key      LanguageKey @relation(fields: [keyId], references: [id], onDelete: Cascade)
  language Language    @relation(fields: [languageCode], references: [code], onDelete: Cascade)

  @@unique([keyId, languageCode])
  @@index([languageCode])
  @@map("language_translations")
}

model BrandProfile {
  id                 String   @id @default(uuid())
  userId             String   @unique @map("user_id")
  companyName        String   @map("company_name")
  website            String?
  logoUrl            String?  @map("logo_url")
  industry           String?
  brandDescription   String?  @map("brand_description")
  creditScore        Int      @default(100) @map("credit_score")
  completedCampaigns Int      @default(0) @map("completed_campaigns")
  brandDnaJson       Json?    @map("brand_dna_json")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@map("brand_profiles")
}

model StudioProfile {
  id          String   @id @default(uuid())
  userId      String   @unique @map("user_id")
  studioName  String   @map("studio_name")
  companyName String   @map("company_name")
  website     String?
  logoUrl     String?  @map("logo_url")
  coverUrl    String?  @map("cover_url")
  country     String?
  city        String?
  description String?
  verified    Boolean  @default(false)
  rating      Decimal? @db.Decimal(3, 2)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user         User                  @relation(fields: [userId], references: [id])
  creators     CreatorProfile[]
  invitations  CreatorInvitation[]

  @@map("studio_profiles")
}

model CreatorProfile {
  id                  String              @id @default(uuid())
  userId              String              @unique @map("user_id")
  studioId            String?             @map("studio_id")
  displayName         String              @map("display_name")
  headline            String?
  bio                 String?
  country             String?
  city                String?
  serviceCitiesJson   Json?               @map("service_cities_json")
  socialLinksJson     Json?               @map("social_links_json")
  stylesJson          Json?               @map("styles_json")
  specialtiesJson     Json?               @map("specialties_json")
  toolsJson           Json?               @map("tools_json")
  expertiseDomainsJson Json?              @map("expertise_domains_json")
  portfolioUrl        String?             @map("portfolio_url")
  aiEnabled           Boolean             @default(true) @map("ai_enabled")
  profileCompletedAt  DateTime?           @map("profile_completed_at")
  legacyCreatorId     String?             @unique @map("legacy_creator_id")
  languagesJson       Json?               @map("languages_json")
  availability        CreatorAvailability @default(AVAILABLE)
  hourlyRate          Decimal?            @map("hourly_rate") @db.Decimal(18, 2)
  minBudget           Decimal?            @map("min_budget") @db.Decimal(18, 2)
  maxBudget           Decimal?            @map("max_budget") @db.Decimal(18, 2)
  creditScore         Int                 @default(100) @map("credit_score")
  aiQualityScore      Int                 @default(80) @map("ai_quality_score")
  completionRate      Decimal             @default(100) @map("completion_rate") @db.Decimal(5, 2)
  averageReviewRound  Decimal             @default(1) @map("average_review_round") @db.Decimal(5, 2)
  averageDeliveryDays Decimal             @default(5) @map("average_delivery_days") @db.Decimal(5, 2)
  completedCampaigns  Int                 @default(0) @map("completed_campaigns")
  creatorDnaJson      Json?               @map("creator_dna_json")
  portfolioCover      String?             @map("portfolio_cover")
  createdAt           DateTime            @default(now()) @map("created_at")
  updatedAt           DateTime            @updatedAt @map("updated_at")

  user        User                 @relation(fields: [userId], references: [id])
  studio      StudioProfile?       @relation(fields: [studioId], references: [id])
  invitations CreatorInvitation[]
  memberships CreatorMembership[]
  portfolioWorks CreatorPortfolioWork[]
  aiConfig    CreatorAiConfig?
  orders      Order[]
  conversations Conversation[]
  attributions  Attribution[]
  connectedChannels ConnectedChannel[]

  @@index([studioId])
  @@index([country])
  @@index([availability])
  @@index([profileCompletedAt])
  @@map("creator_profiles")
}

model CreatorPortfolioWork {
  id            String    @id @default(uuid())
  creatorId     String    @map("creator_id")
  campaignId    String?   @map("campaign_id")
  title         String
  description   String?   @db.Text
  city          String?
  country       String?
  category      String?
  platform      String?
  format        String?
  workType      String?   @map("work_type")
  thumbnailUrl  String?   @map("thumbnail_url")
  thumbnailKey  String?   @map("thumbnail_key")
  videoUrl      String?   @map("video_url")
  videoKey      String?   @map("video_key")
  tagsJson      Json?     @map("tags_json")
  priceMin      Decimal?  @map("price_min") @db.Decimal(18, 2)
  priceMax      Decimal?  @map("price_max") @db.Decimal(18, 2)
  priceVisible  Boolean   @default(false) @map("price_visible")
  isPublic      Boolean   @default(true) @map("is_public")
  sortOrder     Int       @default(0) @map("sort_order")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  creator      CreatorProfile @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  campaign     Campaign?      @relation(fields: [campaignId], references: [id])
  storageFiles StorageFile[]

  @@index([creatorId])
  @@index([campaignId])
  @@index([creatorId, isPublic, sortOrder])
  @@index([deletedAt])
  @@map("creator_portfolio_works")
}

model CreatorAiConfig {
  id                 String   @id @default(uuid())
  creatorId          String   @unique @map("creator_id")
  aiName             String   @map("ai_name")
  persona            String?  @db.Text
  welcomeMessage     String?  @map("welcome_message") @db.Text
  serviceIntro       String?  @map("service_intro") @db.Text
  faqJson            Json?    @map("faq_json")
  pricingRulesJson   Json?    @map("pricing_rules_json")
  receptionScript    String?  @map("reception_script") @db.Text
  multilingualJson   Json?    @map("multilingual_json")
  defaultReply       String?  @map("default_reply") @db.Text
  blockedContentJson Json?    @map("blocked_content_json")
  handoffRulesJson   Json?    @map("handoff_rules_json")
  dataSourcesJson    Json?    @map("data_sources_json")
  isEnabled          Boolean  @default(true) @map("is_enabled")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  creator CreatorProfile @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  @@map("creator_ai_configs")
}

model ConnectedChannel {
  id                String    @id @default(uuid())
  creatorId         String    @map("creator_id")
  platform          String
  accountUrl        String?   @map("account_url")
  accountHandle     String?   @map("account_handle")
  status            String    @default("DISCONNECTED")
  sourceCount       Int       @default(0) @map("source_count")
  aiLearningEnabled Boolean   @default(true) @map("ai_learning_enabled")
  metadataJson      Json?     @map("metadata_json")
  lastSyncedAt      DateTime? @map("last_synced_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  creator CreatorProfile @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  @@unique([creatorId, platform])
  @@index([creatorId])
  @@index([platform])
  @@index([status])
  @@index([aiLearningEnabled])
  @@map("connected_channels")
}

// ─── Campaign (Aggregate Root) ───────────────────────────────────────────────

model Campaign {
  id               String         @id @default(uuid())
  brandId          String         @map("brand_id")
  creatorId        String?        @map("creator_id")
  title            String
  description      String?
  budget           Decimal        @db.Decimal(18, 2)
  currency         String         @default("USD")
  deadline         DateTime
  platform         String?
  aspectRatio      String?        @map("aspect_ratio")
  status           CampaignStatus @default(DRAFT)
  creativeDirection String?       @map("creative_direction")
  productionBrief  Json?          @map("production_brief")
  campaignMemoryJson Json?        @map("campaign_memory_json")
  campaignHealth   Int            @default(100) @map("campaign_health")
  reviewRound      Int            @default(0) @map("review_round")
  paidRevisionSlotsUnlocked  Int            @default(0) @map("paid_revision_slots_unlocked")
  currentVersion   Int            @default(0) @map("current_version")
  createdBy        String?        @map("created_by")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")
  deletedAt        DateTime?      @map("deleted_at")

  brand         User                @relation("BrandCampaigns", fields: [brandId], references: [id])
  creator       User?               @relation("CreatorCampaigns", fields: [creatorId], references: [id])
  assets        CampaignAsset[]
  versions      CampaignVersion[]
  comments      ReviewComment[]
  reviewAnnotations ReviewAnnotation[]
  invitations   CreatorInvitation[]
  escrow        EscrowPayment?
  activities    ActivityLog[]
  notifications Notification[]
  disputes      Dispute[]
  messages      CommunicationMessage[]
  memoryFacts   MemoryFact[]
  performanceSources PerformanceSource[]
  orderCommission OrderCommission?
  orders           Order[]
  portfolioWorks   CreatorPortfolioWork[]
  referralCommissions ReferralCommission[]
  deliveries      CampaignDelivery[]
  ledgerEntries   LedgerEntry[]
  conversations   Conversation[]
  attributions    Attribution[]

  @@index([brandId])
  @@index([creatorId])
  @@index([status])
  @@index([deadline])
  @@index([campaignHealth])
  @@index([createdAt])
  @@map("campaigns")
}

model Order {
  id                 String      @id @default(uuid())
  campaignId         String?     @map("campaign_id")
  clientId           String      @map("client_id")
  creatorId          String      @map("creator_id")
  creatorProfileId   String?     @map("creator_profile_id")
  serviceProject     String      @map("service_project")
  shootingCity       String?     @map("shooting_city")
  shootingDate       DateTime?   @map("shooting_date")
  currency           String      @default("USD")
  orderAmount        Decimal     @map("order_amount") @db.Decimal(18, 2)
  platformCommission Decimal     @default(0) @map("platform_commission") @db.Decimal(18, 2)
  creatorIncome      Decimal     @default(0) @map("creator_income") @db.Decimal(18, 2)
  status             OrderStatus @default(PENDING)
  sourceChannel      String?     @map("source_channel")
  conversationId     String?     @map("conversation_id")
  referrerId         String?     @map("referrer_id")
  metadataJson       Json?       @map("metadata_json")
  createdAt          DateTime    @default(now()) @map("created_at")
  updatedAt          DateTime    @updatedAt @map("updated_at")
  completedAt        DateTime?   @map("completed_at")
  cancelledAt        DateTime?   @map("cancelled_at")
  refundedAt         DateTime?   @map("refunded_at")

  campaign       Campaign?       @relation(fields: [campaignId], references: [id])
  client         User            @relation("ClientOrders", fields: [clientId], references: [id])
  creator        User            @relation("CreatorOrders", fields: [creatorId], references: [id])
  creatorProfile CreatorProfile? @relation(fields: [creatorProfileId], references: [id])
  conversation    Conversation?   @relation(fields: [conversationId], references: [id])
  referrer       User?           @relation("ReferredOrders", fields: [referrerId], references: [id])
  ledgerEntries  LedgerEntry[]
  attributions    Attribution[]
  referralCommissions ReferralCommission[]

  @@index([campaignId])
  @@index([clientId])
  @@index([creatorId])
  @@index([creatorProfileId])
  @@index([conversationId])
  @@index([status])
  @@index([referrerId])
  @@index([createdAt])
  @@map("orders")
}

model Conversation {
  id            String             @id @default(uuid())
  creatorId     String             @map("creator_id")
  visitorId     String?            @map("visitor_id")
  customerId    String?            @map("customer_id")
  campaignId    String?            @map("campaign_id")
  channel       String
  source        String?
  language      String             @default("en")
  status        ConversationStatus @default(OPEN)
  assignedTo    String?            @map("assigned_to")
  lastMessageAt DateTime?          @map("last_message_at")
  startedAt     DateTime           @default(now()) @map("started_at")
  endedAt       DateTime?          @map("ended_at")
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @updatedAt @map("updated_at")

  creator       CreatorProfile        @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  customer      User?                 @relation("CustomerConversations", fields: [customerId], references: [id])
  campaign      Campaign?             @relation(fields: [campaignId], references: [id])
  assignedAgent User?                 @relation("AssignedConversations", fields: [assignedTo], references: [id])
  messages      ConversationMessage[]
  orders        Order[]
  attributions  Attribution[]

  @@index([creatorId])
  @@index([customerId])
  @@index([campaignId])
  @@index([assignedTo])
  @@index([status, lastMessageAt])
  @@index([createdAt])
  @@map("conversations")
}

model ConversationMessage {
  id             String                  @id @default(uuid())
  conversationId String                  @map("conversation_id")
  role           ConversationMessageRole
  content        String                  @db.Text
  metadata       Json?
  tokens         Int?
  createdAt      DateTime                @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([role])
  @@map("conversation_messages")
}

model Attribution {
  id             String   @id @default(uuid())
  orderId        String?  @map("order_id")
  campaignId     String?  @map("campaign_id")
  conversationId String?  @map("conversation_id")
  creatorId      String?  @map("creator_id")
  source         String?
  medium         String?
  content        String?
  utm            Json?
  platform       String?
  clickId        String?  @map("click_id")
  metadataJson   Json?    @map("metadata_json")
  createdAt      DateTime @default(now()) @map("created_at")

  order        Order?          @relation(fields: [orderId], references: [id])
  campaign     Campaign?       @relation(fields: [campaignId], references: [id])
  conversation Conversation?   @relation(fields: [conversationId], references: [id])
  creator      CreatorProfile? @relation(fields: [creatorId], references: [id])

  @@index([orderId])
  @@index([campaignId])
  @@index([conversationId])
  @@index([creatorId])
  @@index([platform])
  @@index([source, medium])
  @@index([createdAt])
  @@map("attributions")
}

model CampaignAsset {
  id              String    @id @default(uuid())
  campaignId      String    @map("campaign_id")
  uploadedBy      String    @map("uploaded_by")
  assetType       AssetType @map("asset_type")
  fileName        String    @map("file_name")
  fileKey         String    @map("file_key")
  storageProvider String    @default("r2") @map("storage_provider")
  mimeType        String    @map("mime_type")
  fileSize        BigInt    @map("file_size")
  width           Int?
  height          Int?
  duration        Decimal?  @db.Decimal(10, 3)
  hash            String?
  previewUrl      String?   @map("preview_url")
  thumbnailUrl    String?   @map("thumbnail_url")
  status          String    @default("READY")
  metadataJson    Json?     @map("metadata_json")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  campaign Campaign @relation(fields: [campaignId], references: [id])

  @@index([campaignId])
  @@index([assetType])
  @@map("campaign_assets")
}

model PerformanceSource {
  id              String                    @id @default(uuid())
  campaignId      String                    @map("campaign_id")
  uploadedBy      String                    @map("uploaded_by")
  platform        PerformanceSourcePlatform
  sourceType      String                    @map("source_type")
  url             String?
  status          PerformanceSourceStatus   @default(PENDING)
  fileKey         String?                   @map("file_key")
  fileName        String?                   @map("file_name")
  mimeType        String?                   @map("mime_type")
  fileSize        BigInt?                   @map("file_size")
  metricsJson     Json?                     @map("metrics_json")
  analysisJson    Json?                     @map("analysis_json")
  errorMessage    String?                   @map("error_message")
  createdAt       DateTime                  @default(now()) @map("created_at")
  updatedAt       DateTime                  @updatedAt @map("updated_at")
  analyzedAt      DateTime?                 @map("analyzed_at")

  campaign Campaign @relation(fields: [campaignId], references: [id])
  uploader User     @relation(fields: [uploadedBy], references: [id])

  @@index([campaignId])
  @@index([uploadedBy])
  @@index([platform])
  @@index([status])
  @@index([createdAt])
  @@map("performance_sources")
}

model CampaignVersion {
  id            String        @id @default(uuid())
  campaignId    String        @map("campaign_id")
  versionNumber Int           @map("version_number")
  uploadedBy    String        @map("uploaded_by")
  videoKey      String        @map("video_key")
  videoUrl      String?       @map("video_url")
  fileName      String?       @map("file_name")
  mimeType      String?       @map("mime_type")
  fileSizeBytes Int?          @map("file_size_bytes")
  hlsUrl        String?       @map("hls_url")
  thumbnailUrl  String?       @map("thumbnail_url")
  duration      Decimal?      @db.Decimal(10, 3)
  watermark     Boolean       @default(true)
  status        VersionStatus @default(UPLOADING)
  reviewRound   Int           @default(0) @map("review_round")
  reviewStatus  ReviewStatus  @default(WAITING) @map("review_status")
  reviewScore   Decimal?      @map("review_score") @db.Decimal(5, 2)
  aiReportJson  Json?         @map("ai_report_json")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  deletedAt     DateTime?     @map("deleted_at")

  campaign   Campaign          @relation(fields: [campaignId], references: [id])
  comments   ReviewComment[]
  annotations ReviewAnnotation[]
  deliveries CampaignDelivery[]

  @@unique([campaignId, versionNumber])
  @@index([campaignId])
  @@index([status])
  @@index([reviewStatus])
  @@map("campaign_versions")
}

// ─── Review ──────────────────────────────────────────────────────────────────

model ReviewComment {
  id         String   @id @default(uuid())
  campaignId String   @map("campaign_id")
  versionId  String   @map("version_id")
  userId     String   @map("user_id")
  timeSeconds Decimal @map("time_seconds") @db.Decimal(10, 3)
  comment    String
  resolved   Boolean  @default(false)
  resolvedBy String?  @map("resolved_by")
  resolvedAt DateTime? @map("resolved_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")

  campaign    Campaign           @relation(fields: [campaignId], references: [id])
  version     CampaignVersion    @relation(fields: [versionId], references: [id])
  user        User               @relation(fields: [userId], references: [id])
  annotations ReviewAnnotation[]

  @@index([campaignId])
  @@index([versionId])
  @@index([userId])
  @@map("review_comments")
}

model ReviewAnnotation {
  id          String         @id @default(uuid())
  commentId   String         @map("comment_id")
  campaignId  String         @map("campaign_id")
  versionId   String         @map("version_id")
  type        AnnotationType
  x           Decimal        @db.Decimal(8, 6)
  y           Decimal        @db.Decimal(8, 6)
  width       Decimal        @db.Decimal(8, 6)
  height      Decimal        @db.Decimal(8, 6)
  color       String         @default("#FF4D4F")
  strokeWidth Int            @default(2) @map("stroke_width")
  dataJson    Json?          @map("data_json")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime?      @updatedAt @map("updated_at")

  comment ReviewComment   @relation(fields: [commentId], references: [id])
  version CampaignVersion @relation(fields: [versionId], references: [id])
  campaign Campaign       @relation(fields: [campaignId], references: [id])

  @@index([commentId])
  @@index([versionId])
  @@index([campaignId])
  @@map("review_annotations")
}

model CampaignDelivery {
  id          String         @id @default(uuid())
  campaignId  String         @unique @map("campaign_id")
  versionId   String         @map("version_id")
  downloadUrl String         @map("download_url")
  deliveredAt DateTime       @default(now()) @map("delivered_at")
  acceptedAt  DateTime?      @map("accepted_at")
  status      DeliveryStatus @default(READY)
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  campaign Campaign        @relation(fields: [campaignId], references: [id])
  version  CampaignVersion @relation(fields: [versionId], references: [id])

  @@index([versionId])
  @@index([status])
  @@map("campaign_deliveries")
}

// ─── Creator Matching ────────────────────────────────────────────────────────

model CreatorInvitation {
  id           String           @id @default(uuid())
  campaignId   String           @map("campaign_id")
  creatorId    String           @map("creator_id")
  studioId     String?          @map("studio_id")
  matchScore   Decimal          @map("match_score") @db.Decimal(5, 2)
  status       InvitationStatus @default(SENT)
  counterOffer Decimal?         @map("counter_offer") @db.Decimal(18, 2)
  declineReason CreatorInvitationDeclineReason? @map("decline_reason")
  declineFeedbackJson Json?      @map("decline_feedback_json")
  respondedAt  DateTime?        @map("responded_at")
  expiresAt    DateTime?        @map("expires_at")
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")

  campaign Campaign       @relation(fields: [campaignId], references: [id])
  creator  CreatorProfile @relation(fields: [creatorId], references: [id])
  studio   StudioProfile? @relation(fields: [studioId], references: [id])

  @@index([campaignId])
  @@index([creatorId])
  @@index([studioId])
  @@index([status])
  @@index([declineReason])
  @@map("creator_invitations")
}

// ─── Payment & Wallet ────────────────────────────────────────────────────────

model EscrowPayment {
  id                     String                   @id @default(uuid())
  campaignId             String                   @unique @map("campaign_id")
  brandId                String                   @map("brand_id")
  creatorId              String                   @map("creator_id")
  stripePaymentId        String?                  @map("stripe_payment_id")
  stripeSessionId        String?                  @map("stripe_session_id")
  currency               String                   @default("USD")
  amount                 Decimal                  @db.Decimal(18, 2)
  releasedAmount         Decimal                  @default(0) @map("released_amount") @db.Decimal(18, 2)
  remainingAmount        Decimal                  @map("remaining_amount") @db.Decimal(18, 2)
  status                 EscrowStatus             @default(CREATED)
  paymentStatus          PaymentCollectionStatus  @default(UNPAID) @map("payment_status")
  creatorPayoutStatus    CreatorPayoutStatus?     @map("creator_payout_status")
  paidAt                 DateTime?                @map("paid_at")
  payoutPaidAt           DateTime?                @map("payout_paid_at")
  payoutMarkedByAdminId  String?                  @map("payout_marked_by_admin_id")
  createdAt              DateTime                 @default(now()) @map("created_at")
  updatedAt              DateTime                 @updatedAt @map("updated_at")

  campaign Campaign @relation(fields: [campaignId], references: [id])

  @@index([brandId])
  @@index([creatorId])
  @@index([status])
  @@index([paymentStatus])
  @@index([creatorPayoutStatus])
  @@map("escrow_payments")
}

model Wallet {
  id               String   @id @default(uuid())
  userId           String   @unique @map("user_id")
  currency         String   @default("USD")
  availableBalance Decimal  @default(0) @map("available_balance") @db.Decimal(18, 2)
  pendingBalance   Decimal  @default(0) @map("pending_balance") @db.Decimal(18, 2)
  totalEarned      Decimal  @default(0) @map("total_earned") @db.Decimal(18, 2)
  totalWithdraw    Decimal  @default(0) @map("total_withdraw") @db.Decimal(18, 2)
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  user         User          @relation(fields: [userId], references: [id])
  transactions Transaction[]

  @@map("wallets")
}

model Transaction {
  id           String          @id @default(uuid())
  walletId     String          @map("wallet_id")
  campaignId   String?         @map("campaign_id")
  type         TransactionType
  amount       Decimal         @db.Decimal(18, 2)
  balanceAfter Decimal         @map("balance_after") @db.Decimal(18, 2)
  description  String?
  createdAt    DateTime        @default(now()) @map("created_at")

  wallet Wallet @relation(fields: [walletId], references: [id])

  @@index([walletId])
  @@index([campaignId])
  @@index([type])
  @@map("transactions")
}

// ─── Unified Finance (WalletAccount / WalletAsset / LedgerEntry) ─────────────

model WalletAccount {
  id        String              @id @default(uuid())
  userId    String              @unique @map("user_id")
  status    WalletAccountStatus @default(ACTIVE)
  createdAt DateTime            @default(now()) @map("created_at")
  updatedAt DateTime            @updatedAt @map("updated_at")

  user    User          @relation(fields: [userId], references: [id])
  assets  WalletAsset[]
  entries LedgerEntry[]
  withdrawalRequests WithdrawalRequest[]

  @@map("wallet_accounts")
}

model WalletAsset {
  id               String          @id @default(uuid())
  walletAccountId  String          @map("wallet_account_id")
  assetCode        WalletAssetCode @map("asset_code")
  availableBalance Decimal         @default(0) @map("available_balance") @db.Decimal(24, 8)
  pendingBalance   Decimal         @default(0) @map("pending_balance") @db.Decimal(24, 8)
  frozenBalance    Decimal         @default(0) @map("frozen_balance") @db.Decimal(24, 8)
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")

  walletAccount WalletAccount @relation(fields: [walletAccountId], references: [id], onDelete: Cascade)

  @@unique([walletAccountId, assetCode])
  @@index([walletAccountId])
  @@map("wallet_assets")
}

model PaymentMethod {
  id            String                @id @default(uuid())
  userId        String                @map("user_id")
  type          PaymentMethodType
  provider      PaymentMethodProvider
  accountName   String?               @map("account_name")
  accountNumber String?               @map("account_number")
  accountEmail  String?               @map("account_email")
  walletAddress String?               @map("wallet_address")
  network       String?
  currency      WalletAssetCode       @default(USD)
  isDefault     Boolean               @default(false) @map("is_default")
  status        PaymentMethodStatus   @default(PENDING)
  metadataJson  Json?                 @map("metadata_json")
  createdAt     DateTime              @default(now()) @map("created_at")
  updatedAt     DateTime              @updatedAt @map("updated_at")

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  ledgerEntries LedgerEntry[]
  withdrawalRequests WithdrawalRequest[]

  @@index([userId])
  @@index([userId, isDefault])
  @@index([status])
  @@map("payment_methods")
}

model LedgerEntry {
  id                    String          @id @default(uuid())
  walletAccountId       String          @map("wallet_account_id")
  assetCode             WalletAssetCode @map("asset_code")
  entryType             LedgerEntryType @map("entry_type")
  direction             LedgerDirection
  amount                Decimal         @db.Decimal(24, 8)
  availableAfter        Decimal         @map("available_after") @db.Decimal(24, 8)
  pendingAfter          Decimal         @map("pending_after") @db.Decimal(24, 8)
  frozenAfter           Decimal         @map("frozen_after") @db.Decimal(24, 8)
  campaignId            String?         @map("campaign_id")
  orderId               String?         @map("order_id")
  paymentMethodId       String?         @map("payment_method_id")
  withdrawalRequestId   String?         @map("withdrawal_request_id")
  channel               PaymentChannel?
  referenceType         String?         @map("reference_type")
  referenceId           String?         @map("reference_id")
  cryptoNetwork         String?         @map("crypto_network")
  txHash                String?         @map("tx_hash")
  externalWalletAddress String?         @map("external_wallet_address")
  description           String?
  metadataJson          Json?           @map("metadata_json")
  createdAt             DateTime        @default(now()) @map("created_at")

  walletAccount WalletAccount  @relation(fields: [walletAccountId], references: [id], onDelete: Cascade)
  paymentMethod PaymentMethod? @relation(fields: [paymentMethodId], references: [id])
  campaign      Campaign?      @relation(fields: [campaignId], references: [id])
  order         Order?         @relation(fields: [orderId], references: [id])
  withdrawalRequest WithdrawalRequest? @relation(fields: [withdrawalRequestId], references: [id])

  @@index([walletAccountId, createdAt])
  @@index([walletAccountId, assetCode])
  @@index([campaignId])
  @@index([orderId])
  @@index([entryType])
  @@index([withdrawalRequestId])
  @@index([channel])
  @@index([txHash])
  @@map("ledger_entries")
}

model WithdrawalRequest {
  id              String                  @id @default(uuid())
  walletAccountId String                 @map("wallet_account_id")
  paymentMethodId String?                @map("payment_method_id")
  assetCode       WalletAssetCode        @default(USD) @map("asset_code")
  amount          Decimal                @db.Decimal(24, 8)
  status          WithdrawalRequestStatus @default(PENDING)
  note            String?
  metadataJson    Json?                  @map("metadata_json")
  createdAt       DateTime               @default(now()) @map("created_at")
  updatedAt       DateTime               @updatedAt @map("updated_at")
  resolvedAt      DateTime?              @map("resolved_at")

  walletAccount WalletAccount @relation(fields: [walletAccountId], references: [id], onDelete: Cascade)
  paymentMethod PaymentMethod? @relation(fields: [paymentMethodId], references: [id])
  ledgerEntries LedgerEntry[]

  @@index([walletAccountId])
  @@index([paymentMethodId])
  @@index([status, createdAt])
  @@map("withdrawal_requests")
}

model ReferralCode {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  code      String   @unique
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isActive])
  @@map("referral_codes")
}

model ReferralRelation {
  id             String   @id @default(uuid())
  referrerUserId String   @map("referrer_user_id")
  referredUserId String   @map("referred_user_id")
  source         String?
  createdAt      DateTime @default(now()) @map("created_at")

  referrer User @relation("ReferralsMade", fields: [referrerUserId], references: [id], onDelete: Cascade)
  referred User @relation("ReferralsReceived", fields: [referredUserId], references: [id], onDelete: Cascade)

  @@unique([referredUserId])
  @@index([referrerUserId])
  @@map("referral_relations")
}

model ReferralCommission {
  id              String                   @id @default(uuid())
  referrerUserId  String                   @map("referrer_user_id")
  referredUserId  String?                  @map("referred_user_id")
  orderId         String?                  @map("order_id")
  campaignId      String?                  @map("campaign_id")
  source          String?
  dealAmount      Decimal                  @map("deal_amount") @db.Decimal(18, 2)
  commissionRate  Decimal                  @map("commission_rate") @db.Decimal(5, 2)
  commissionAmount Decimal                 @map("commission_amount") @db.Decimal(18, 2)
  status          ReferralCommissionStatus @default(PENDING)
  createdAt       DateTime                 @default(now()) @map("created_at")
  updatedAt       DateTime                 @updatedAt @map("updated_at")
  paidAt          DateTime?                @map("paid_at")

  referrer User      @relation("ReferralCommissions", fields: [referrerUserId], references: [id], onDelete: Cascade)
  order    Order?    @relation(fields: [orderId], references: [id])
  campaign Campaign? @relation(fields: [campaignId], references: [id])

  @@index([referrerUserId])
  @@index([referredUserId])
  @@index([orderId])
  @@index([campaignId])
  @@index([status])
  @@map("referral_commissions")
}

// ─── Events & Notifications ──────────────────────────────────────────────────

model DomainEvent {
  id            String      @id @default(uuid())
  eventName     String      @map("event_name")
  aggregateType String      @map("aggregate_type")
  aggregateId   String      @map("aggregate_id")
  payloadJson   Json        @map("payload_json")
  status        EventStatus @default(PENDING)
  retryCount    Int         @default(0) @map("retry_count")
  createdAt     DateTime    @default(now()) @map("created_at")
  processedAt   DateTime?   @map("processed_at")

  @@index([eventName])
  @@index([aggregateId])
  @@index([status])
  @@map("domain_events")
}

model Notification {
  id         String               @id @default(uuid())
  userId     String               @map("user_id")
  campaignId String?              @map("campaign_id")
  channel    NotificationChannel  @default(IN_APP)
  priority   NotificationPriority @default(NORMAL)
  title      String
  content    String
  actionUrl  String?              @map("action_url")
  isRead     Boolean              @default(false) @map("is_read")
  isSent     Boolean              @default(false) @map("is_sent")
  createdAt  DateTime             @default(now()) @map("created_at")
  readAt     DateTime?            @map("read_at")

  user     User      @relation(fields: [userId], references: [id])
  campaign Campaign? @relation(fields: [campaignId], references: [id])

  @@index([userId])
  @@index([campaignId])
  @@index([isRead])
  @@map("notifications")
}

model ActivityLog {
  id         String   @id @default(uuid())
  campaignId String   @map("campaign_id")
  userId     String?  @map("user_id")
  action     String
  ip         String?
  device     String?
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")

  campaign Campaign @relation(fields: [campaignId], references: [id])
  user     User?    @relation(fields: [userId], references: [id])

  @@index([campaignId])
  @@index([userId])
  @@index([createdAt])
  @@map("activity_logs")
}

model Dispute {
  id        String        @id @default(uuid())
  campaignId String       @map("campaign_id")
  openedBy  String        @map("opened_by")
  reason    String
  status    DisputeStatus @default(OPEN)
  adminId   String?       @map("admin_id")
  result    String?
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")

  campaign Campaign @relation(fields: [campaignId], references: [id])

  @@index([campaignId])
  @@index([status])
  @@map("disputes")
}

// ─── Prisma v2 — Vol 18 extended tables ─────────────────────────────────────

enum AiJobStatus {
  QUEUED
  RUNNING
  VALIDATING
  SUCCESS
  FAILED
  RETRYING
  DEAD
}

enum QueueJobStatus {
  WAITING
  RUNNING
  SUCCESS
  FAILED
  RETRY
  DEAD
}

model AiJob {
  id            String      @id @default(uuid())
  campaignId    String?     @map("campaign_id")
  type          String
  provider      String      @default("openai")
  status        AiJobStatus @default(QUEUED)
  inputJson     Json        @map("input_json")
  outputJson    Json?       @map("output_json")
  promptVersion String?     @map("prompt_version")
  tokenInput    Int         @default(0) @map("token_input")
  tokenOutput   Int         @default(0) @map("token_output")
  cost          Decimal     @default(0) @db.Decimal(18, 6)
  latencyMs     Int?        @map("latency_ms")
  retryCount    Int         @default(0) @map("retry_count")
  createdAt     DateTime    @default(now()) @map("created_at")
  completedAt   DateTime?   @map("completed_at")

  @@index([campaignId])
  @@index([status])
  @@index([type])
  @@map("ai_jobs")
}

model AIEvent {
  id         String   @id @default(uuid())
  eventType  String   @map("event_type")
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  payload    Json
  processed  Boolean  @default(false)
  retry      Int      @default(0)
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([eventType])
  @@index([entityType, entityId])
  @@index([processed])
  @@map("ai_events")
}

model AILearning {
  id            String   @id @default(uuid())
  sourceEventId String   @map("source_event_id")
  entityType    String   @map("entity_type")
  entityId      String   @map("entity_id")
  learningType  String   @map("learning_type")
  before        Json?
  after         Json
  confidence    Float
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([sourceEventId])
  @@index([entityType, entityId])
  @@index([learningType])
  @@map("ai_learning")
}

model WebhookEvent {
  id          String   @id @default(uuid())
  provider    String
  eventType   String   @map("event_type")
  payloadJson Json     @map("payload_json")
  processed   Boolean  @default(false)
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([provider])
  @@index([processed])
  @@map("webhook_events")
}

model FeatureFlag {
  id        String   @id @default(uuid())
  key       String   @unique
  enabled   Boolean  @default(false)
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("feature_flags")
}

model VideoJob {
  id         String         @id @default(uuid())
  campaignId String         @map("campaign_id")
  versionId  String?        @map("version_id")
  queue      String
  status     QueueJobStatus @default(WAITING)
  payloadJson Json          @map("payload_json")
  retryCount Int            @default(0) @map("retry_count")
  error      String?
  startedAt  DateTime?      @map("started_at")
  finishedAt DateTime?      @map("finished_at")
  createdAt  DateTime       @default(now()) @map("created_at")

  @@index([campaignId])
  @@index([status])
  @@index([queue])
  @@map("video_jobs")
}

model QueueJob {
  id          String         @id @default(uuid())
  queue       String
  status      QueueJobStatus @default(WAITING)
  payloadJson Json           @map("payload_json")
  retryCount  Int            @default(0) @map("retry_count")
  error       String?
  startedAt   DateTime?      @map("started_at")
  finishedAt  DateTime?      @map("finished_at")
  createdAt   DateTime       @default(now()) @map("created_at")

  @@index([queue])
  @@index([status])
  @@map("queue_jobs")
}

model WorkerLog {
  id         String   @id @default(uuid())
  workerName String   @map("worker_name")
  jobId      String?  @map("job_id")
  level      String
  message    String
  metadata   Json?
  durationMs Int?     @map("duration_ms")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([workerName])
  @@index([jobId])
  @@map("worker_logs")
}

model EmailLog {
  id        String   @id @default(uuid())
  userId    String?  @map("user_id")
  toEmail   String   @map("to_email")
  template  String
  status    String
  error     String?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([status])
  @@map("email_logs")
}

model SessionLog {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  ip        String?
  device    String?
  browser   String?
  country   String?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("session_logs")
}

model StorageFile {
  id          String   @id @default(uuid())
  campaignId  String?  @map("campaign_id")
  userId      String?  @map("user_id")
  portfolioWorkId String? @map("portfolio_work_id")
  fileName    String?  @map("file_name")
  fileType    String?  @map("file_type")
  fileKey     String   @map("file_key")
  publicUrl   String?  @map("public_url")
  mimeType    String   @map("mime_type")
  fileSize    BigInt   @map("file_size")
  provider    String   @default("r2")
  createdAt   DateTime @default(now()) @map("created_at")

  user          User?                 @relation(fields: [userId], references: [id])
  portfolioWork CreatorPortfolioWork? @relation(fields: [portfolioWorkId], references: [id])

  @@index([campaignId])
  @@index([userId])
  @@index([portfolioWorkId])
  @@index([fileKey])
  @@map("storage_files")
}

// ─── AI Communication Engine ─────────────────────────────────────────────────

enum CommunicationSourceType {
  CHAT
  REVIEW_COMMENT
  CAMPAIGN_BRIEF
  CREATIVE_SCRIPT
  CREATOR_QUOTE
  PORTFOLIO
  CONTRACT
  EMAIL
  NOTIFICATION
  DISPUTE
  SYSTEM
}

model CommunicationMessage {
  id                   String                  @id @default(uuid())
  campaignId           String?                 @map("campaign_id")
  senderId             String                  @map("sender_id")
  receiverId           String?                 @map("receiver_id")
  sourceType           CommunicationSourceType @default(CHAT) @map("source_type")
  sourceRefId          String?                 @map("source_ref_id")
  originalLanguage     String                  @map("original_language")
  targetLanguage       String                  @map("target_language")
  originalContent      String                  @map("original_content") @db.Text
  localizedContent     String?                 @map("localized_content") @db.Text
  summary              String?                 @db.Text
  todosJson            Json?                   @map("todos_json")
  detectConfidence     Decimal?                @map("detect_confidence") @db.Decimal(5, 4)
  translationAvailable Boolean                 @default(true) @map("translation_available")
  createdAt            DateTime                @default(now()) @map("created_at")
  updatedAt            DateTime                @updatedAt @map("updated_at")
  deletedAt            DateTime?               @map("deleted_at")

  campaign         Campaign?                     @relation(fields: [campaignId], references: [id])
  sender           User                          @relation("SentMessages", fields: [senderId], references: [id])
  receiver         User?                         @relation("ReceivedMessages", fields: [receiverId], references: [id])
  translationLogs  CommunicationTranslationLog[]

  @@index([campaignId])
  @@index([senderId])
  @@index([receiverId])
  @@index([sourceType, sourceRefId])
  @@index([createdAt])
  @@map("communication_messages")
}

model CommunicationTranslationLog {
  id            String   @id @default(uuid())
  messageId     String   @map("message_id")
  model         String
  provider      String
  sourceLang    String   @map("source_lang")
  targetLang    String   @map("target_lang")
  promptVersion String   @map("prompt_version")
  tokenInput    Int      @default(0) @map("token_input")
  tokenOutput   Int      @default(0) @map("token_output")
  cost          Decimal  @default(0) @db.Decimal(18, 6)
  latencyMs     Int      @default(0) @map("latency_ms")
  attempt       Int      @default(1)
  success       Boolean  @default(true)
  error         String?
  createdAt     DateTime @default(now()) @map("created_at")

  message CommunicationMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@index([createdAt])
  @@map("communication_translation_logs")
}

// ─── AI Memory (Brand / Creator / Relationship DNA) ───────────────────────────

enum AiTonePreference {
  PROFESSIONAL
  LUXURY
  GEN_Z
  CORPORATE
  CASUAL
}

enum MemoryOwnerType {
  BRAND
  CREATOR
  CAMPAIGN
  RELATIONSHIP
}

model AiPreference {
  userId            String           @id @map("user_id")
  preferredLanguage String?          @map("preferred_language")
  alwaysTranslate   Boolean          @default(true) @map("always_translate")
  neverUseEmojis    Boolean          @default(false) @map("never_use_emojis")
  tone              AiTonePreference @default(PROFESSIONAL)
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("ai_preferences")
}

model MemoryFact {
  id          String          @id @default(uuid())
  ownerType   MemoryOwnerType @map("owner_type")
  brandId     String?         @map("brand_id")
  creatorId   String?         @map("creator_id")
  campaignId  String?         @map("campaign_id")
  category    String
  factKey     String          @map("fact_key")
  factValue   String          @map("fact_value") @db.Text
  confidence  Decimal         @default(0.8) @db.Decimal(5, 4)
  sourceType  String          @map("source_type")
  sourceRefId String?         @map("source_ref_id")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  campaign Campaign? @relation(fields: [campaignId], references: [id])

  @@unique([ownerType, brandId, creatorId, campaignId, category, factKey])
  @@index([brandId])
  @@index([creatorId])
  @@index([campaignId])
  @@index([ownerType])
  @@map("memory_facts")
}

model RelationshipDna {
  id                  String    @id @default(uuid())
  brandId             String    @map("brand_id")
  creatorId           String    @map("creator_id")
  collaborationCount  Int       @default(0) @map("collaboration_count")
  avgSatisfaction     Decimal?  @map("avg_satisfaction") @db.Decimal(3, 2)
  avgReviewRounds     Decimal?  @map("avg_review_rounds") @db.Decimal(5, 2)
  avgDaysEarly        Decimal?  @map("avg_days_early") @db.Decimal(5, 2)
  priorityScore       Int       @default(0) @map("priority_score")
  lastCollaborationAt DateTime? @map("last_collaboration_at")
  dnaJson             Json?     @map("dna_json")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  brand   User @relation("BrandRelationships", fields: [brandId], references: [id])
  creator User @relation("CreatorRelationships", fields: [creatorId], references: [id])

  @@unique([brandId, creatorId])
  @@index([brandId])
  @@index([creatorId])
  @@index([priorityScore])
  @@map("relationship_dna")
}

// ─── Creator Membership & Commission ─────────────────────────────────────────

model CreatorMembershipPlan {
  id                         String                    @id @default(uuid())
  slug                       String                    @unique
  name                       String
  planType                   CreatorMembershipPlanType @map("plan_type")
  annualFee                  Decimal                   @default(0) @map("annual_fee") @db.Decimal(18, 2)
  creatorCommissionPercentage Decimal                  @map("creator_commission_percentage") @db.Decimal(5, 2)
  membershipDurationDays     Int                       @default(365) @map("membership_duration_days")
  benefitsJson               Json                      @default("[]") @map("benefits_json")
  stripePriceId              String?                   @map("stripe_price_id")
  isActive                   Boolean                   @default(true) @map("is_active")
  sortOrder                  Int                       @default(0) @map("sort_order")
  createdAt                  DateTime                  @default(now()) @map("created_at")
  updatedAt                  DateTime                  @updatedAt @map("updated_at")

  memberships CreatorMembership[]
  history     CreatorMembershipHistory[]

  @@index([planType, isActive])
  @@map("creator_membership_plans")
}

model CreatorMembership {
  id              String                         @id @default(uuid())
  creatorId       String                         @map("creator_id")
  creatorProfileId String?                       @map("creator_profile_id")
  planId          String                         @map("plan_id")
  status          CreatorMembershipStatus        @default(ACTIVE)
  paymentProvider CreatorMembershipPaymentProvider? @map("payment_provider")
  startedAt       DateTime                       @map("started_at")
  expiresAt       DateTime?                      @map("expires_at")
  paymentId       String?                        @map("payment_id")
  stripeSessionId String?                        @map("stripe_session_id")
  amountPaid      Decimal?                       @map("amount_paid") @db.Decimal(18, 2)
  currency        String                         @default("USD")
  metadataJson    Json?                          @map("metadata_json")
  createdAt       DateTime                       @default(now()) @map("created_at")
  updatedAt       DateTime                       @updatedAt @map("updated_at")

  creator User                  @relation(fields: [creatorId], references: [id])
  profile CreatorProfile?       @relation(fields: [creatorProfileId], references: [id])
  plan    CreatorMembershipPlan @relation(fields: [planId], references: [id])

  @@index([creatorId, status])
  @@index([expiresAt])
  @@index([planId])
  @@map("creator_memberships")
}

model CommissionRule {
  id                                String   @id @default(uuid())
  name                              String   @default("default")
  clientServiceFeePercentage        Decimal  @map("client_service_fee_percentage") @db.Decimal(5, 2)
  defaultCreatorCommissionPercentage Decimal @map("default_creator_commission_percentage") @db.Decimal(5, 2)
  verifiedCreatorCommissionPercentage Decimal @map("verified_creator_commission_percentage") @db.Decimal(5, 2)
  upgradeRevenueThreshold           Decimal  @map("upgrade_revenue_threshold") @db.Decimal(18, 2)
  upgradeModalEnabled               Boolean  @default(true) @map("upgrade_modal_enabled")
  clientServiceFeeEnabled           Boolean  @default(true) @map("client_service_fee_enabled")
  isActive                          Boolean  @default(true) @map("is_active")
  createdAt                         DateTime @default(now()) @map("created_at")
  updatedAt                         DateTime @updatedAt @map("updated_at")

  @@index([isActive])
  @@map("commission_rules")
}

model OrderCommission {
  id                            String                    @id @default(uuid())
  campaignId                    String                    @map("campaign_id")
  orderId                       String?                   @map("order_id")
  creatorId                     String                    @map("creator_id")
  orderAmount                   Decimal                   @map("order_amount") @db.Decimal(18, 2)
  currency                      String                    @default("USD")
  clientServiceFeePercentage    Decimal                   @map("client_service_fee_percentage") @db.Decimal(5, 2)
  clientServiceFeeAmount          Decimal                   @map("client_service_fee_amount") @db.Decimal(18, 2)
  creatorCommissionPercentage   Decimal                   @map("creator_commission_percentage") @db.Decimal(5, 2)
  creatorCommissionAmount         Decimal                   @map("creator_commission_amount") @db.Decimal(18, 2)
  creatorPayoutAmount             Decimal                   @map("creator_payout_amount") @db.Decimal(18, 2)
  platformTotalRevenue            Decimal                   @map("platform_total_revenue") @db.Decimal(18, 2)
  creatorMembershipTypeAtOrder    CreatorMembershipPlanType @map("creator_membership_type_at_order_time")
  commissionRuleId                String?                   @map("commission_rule_id")
  planId                          String?                   @map("plan_id")
  settledAt                       DateTime                  @default(now()) @map("settled_at")
  createdAt                       DateTime                  @default(now()) @map("created_at")

  campaign Campaign @relation(fields: [campaignId], references: [id])
  creator  User     @relation("CreatorOrderCommissions", fields: [creatorId], references: [id])

  @@unique([campaignId])
  @@index([creatorId])
  @@index([settledAt])
  @@map("order_commissions")
}

model CreatorEarnings {
  creatorId            String    @id @map("creator_id")
  totalSettledRevenue  Decimal   @default(0) @map("total_settled_revenue") @db.Decimal(18, 2)
  totalPendingRevenue  Decimal   @default(0) @map("total_pending_revenue") @db.Decimal(18, 2)
  totalWithdrawn       Decimal   @default(0) @map("total_withdrawn") @db.Decimal(18, 2)
  totalCreatorPayout   Decimal   @default(0) @map("total_creator_payout") @db.Decimal(18, 2)
  upgradeDeclinedAt    DateTime? @map("upgrade_declined_at")
  lastUpgradePromptAt  DateTime? @map("last_upgrade_prompt_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  creator User @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  @@map("creator_earnings")
}

model CreatorMembershipHistory {
  id        String                         @id @default(uuid())
  creatorId String                         @map("creator_id")
  planId    String?                        @map("plan_id")
  membershipId String?                     @map("membership_id")
  action    CreatorMembershipHistoryAction
  actorId   String?                        @map("actor_id")
  note      String?
  metadataJson Json?                         @map("metadata_json")
  createdAt DateTime                       @default(now()) @map("created_at")

  creator User                   @relation("CreatorMembershipHistory", fields: [creatorId], references: [id])
  plan    CreatorMembershipPlan? @relation(fields: [planId], references: [id])

  @@index([creatorId, createdAt])
  @@map("creator_membership_history")
}
