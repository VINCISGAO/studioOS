  VIEWED
  ACCEPTED
  DECLINED
  COUNTER
  EXPIRED
}

enum CreatorInvitationDeclineReason {
  BUDGET_TOO_LOW
  SCHEDULE_CONFLICT
  NOT_MY_CATEGORY
  BRIEF_INSUFFICIENT
  DEADLINE_TOO_TIGHT
  BRAND_RISK
