// StudioOS — Development Bible Vol 02 + Vol 14
// Campaign-centric schema. All business data links to Campaign.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum UserRole {
  BRAND
  CREATOR
  STUDIO
  ADMIN
  SUPPORT
  SYSTEM
}

enum UserStatus {
  ACTIVE
  PENDING
  SUSPENDED
  BANNED
}

enum CreatorAvailability {
  AVAILABLE
  BUSY
  VACATION
  OFFLINE
}

enum CampaignStatus {
  DRAFT
  AI_PROCESSING
  CREATIVE_READY
  CREATIVE_APPROVED
  MATCHING
  INVITATION_SENT
  CREATOR_ACCEPTED
  ESCROW_PENDING
  ESCROW_FUNDED
  PRODUCING
  UNDER_REVIEW
  APPROVED
  MASTER_UPLOADED
  SETTLEMENT
  COMPLETED
  CANCELLED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  REFUNDED
}

enum ReferralCommissionStatus {
  PENDING
  APPROVED
  PAID
  CANCELLED
}

enum WithdrawalRequestStatus {
  PENDING
  APPROVED
  PAID
  REJECTED
  CANCELLED
}

enum ConversationStatus {
  OPEN
  AI_ACTIVE
  HUMAN_REQUIRED
  HUMAN_ACTIVE
  CLOSED
}

enum ConversationMessageRole {
  USER
  ASSISTANT
  SYSTEM
  HUMAN_AGENT
}

enum AssetType {
  LOGO
  PRODUCT_IMAGE
  PRODUCT_VIDEO
  BRAND_GUIDE
  FONT
  MUSIC
  REFERENCE_VIDEO
  REFERENCE_IMAGE
  PDF
  ZIP
  OTHER
}

enum PerformanceSourceStatus {
  PENDING
  IMPORTED
  ANALYZED
  FAILED
}

enum PerformanceSourcePlatform {
  TIKTOK
  YOUTUBE
  INSTAGRAM
  TELEGRAM
  FACEBOOK_ADS
  WHATSAPP
  XIAOHONGSHU
  DOUYIN
  X
  GOOGLE_DRIVE
  REPORT
  OTHER
}

enum VersionStatus {
  UPLOADING
  PROCESSING
  TRANSCODING
  GENERATING_HLS
  AI_ANALYZING
  READY
  REVIEWING
  APPROVED
  MASTER
  FAILED
}

enum ReviewStatus {
  WAITING
  READY
  REVIEWING
  REVISION_REQUIRED
  APPROVED
  LOCKED
}

enum DeliveryStatus {
