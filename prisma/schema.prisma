model OrderCommission {
  id                           String                    @id @default(uuid())
  campaignId                   String                    @unique @map("campaign_id")
  orderId                      String?                   @map("order_id")
  creatorId                    String                    @map("creator_id")
  orderAmount                  Decimal                   @map("order_amount") @db.Decimal(18, 2)
  currency                     String                    @default("USD")
  clientServiceFeePercentage   Decimal                   @map("client_service_fee_percentage") @db.Decimal(5, 2)
  clientServiceFeeAmount       Decimal                   @map("client_service_fee_amount") @db.Decimal(18, 2)
  creatorCommissionPercentage  Decimal                   @map("creator_commission_percentage") @db.Decimal(5, 2)
  creatorCommissionAmount      Decimal                   @map("creator_commission_amount") @db.Decimal(18, 2)
  creatorPayoutAmount          Decimal                   @map("creator_payout_amount") @db.Decimal(18, 2)
  platformTotalRevenue         Decimal                   @map("platform_total_revenue") @db.Decimal(18, 2)
  creatorMembershipTypeAtOrder CreatorMembershipPlanType @map("creator_membership_type_at_order_time")
  commissionRuleId             String?                   @map("commission_rule_id")
  planId                       String?                   @map("plan_id")
  settledAt                    DateTime                  @default(now()) @map("settled_at")
  createdAt                    DateTime                  @default(now()) @map("created_at")
  campaign                     Campaign                  @relation(fields: [campaignId], references: [id])
  creator                      User                      @relation("CreatorOrderCommissions", fields: [creatorId], references: [id])

  @@index([creatorId])
  @@index([settledAt])
  @@map("order_commissions")
}

model CreatorEarnings {
  creatorId           String    @id @map("creator_id")
  totalSettledRevenue Decimal   @default(0) @map("total_settled_revenue") @db.Decimal(18, 2)
  totalPendingRevenue Decimal   @default(0) @map("total_pending_revenue") @db.Decimal(18, 2)
  totalWithdrawn      Decimal   @default(0) @map("total_withdrawn") @db.Decimal(18, 2)
  totalCreatorPayout  Decimal   @default(0) @map("total_creator_payout") @db.Decimal(18, 2)
  upgradeDeclinedAt   DateTime? @map("upgrade_declined_at")
  lastUpgradePromptAt DateTime? @map("last_upgrade_prompt_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")
  creator             User      @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  @@map("creator_earnings")
}

model CreatorMembershipHistory {
  id           String                         @id @default(uuid())
  creatorId    String                         @map("creator_id")
  planId       String?                        @map("plan_id")
  membershipId String?                        @map("membership_id")
  action       CreatorMembershipHistoryAction
  actorId      String?                        @map("actor_id")
  note         String?
  metadataJson Json?                          @map("metadata_json")
  createdAt    DateTime                       @default(now()) @map("created_at")
  creator      User                           @relation("CreatorMembershipHistory", fields: [creatorId], references: [id])
  plan         CreatorMembershipPlan?         @relation(fields: [planId], references: [id])

  @@index([creatorId, createdAt])
  @@map("creator_membership_history")
}

model PartnerProgram {
  id                 String        @id @default(dbgenerated("gen_random_uuid()"))
  campaignId         String?       @map("campaign_id")
  name               String
  slug               String        @unique
  tier               PartnerTier   @default(STARTER)
  status             PartnerStatus @default(ACTIVE)
  contactName        String?       @map("contact_name")
  contactEmail       String?       @map("contact_email")
  region             String?
  referralCode       String        @unique @map("referral_code")
  commissionRate     Decimal       @default(10) @map("commission_rate") @db.Decimal(5, 2)
  attributedBrands   Int           @default(0) @map("attributed_brands")
  attributedCreators Int           @default(0) @map("attributed_creators")
  attributedRevenue  Decimal       @default(0) @map("attributed_revenue") @db.Decimal(18, 2)
  pendingCommission  Decimal       @default(0) @map("pending_commission") @db.Decimal(18, 2)
  paidCommission     Decimal       @default(0) @map("paid_commission") @db.Decimal(18, 2)
  notes              String?
  metadataJson       Json?         @map("metadata_json")
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")
  campaign           Campaign?     @relation(fields: [campaignId], references: [id])

  @@index([campaignId])
  @@index([status])
  @@index([tier])
  @@index([region])
  @@map("partner_programs")
}

model AcademyCourse {
  id              String               @id @default(dbgenerated("gen_random_uuid()"))
  campaignId      String?              @map("campaign_id")
  slug            String               @unique
  title           String
  subtitle        String?
  audience        AcademyAudience
  status          AcademyContentStatus @default(DRAFT)
  level           String               @default("Beginner")
  durationMinutes Int                  @default(15) @map("duration_minutes")
  lessonCount     Int                  @default(1) @map("lesson_count")
  completionCount Int                  @default(0) @map("completion_count")
  owner           String               @default("VINCIS")
  description     String?
  outcomesJson    Json?                @map("outcomes_json")
  metadataJson    Json?                @map("metadata_json")
  publishedAt     DateTime?            @map("published_at")
  createdAt       DateTime             @default(now()) @map("created_at")
  updatedAt       DateTime             @updatedAt @map("updated_at")
  campaign        Campaign?            @relation(fields: [campaignId], references: [id])

  @@index([campaignId])
  @@index([audience])
  @@index([status])
  @@index([publishedAt])
  @@map("academy_courses")
}

