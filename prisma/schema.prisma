generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

model User {
  id                    String                     @id @default(uuid())
  email                 String                     @unique
  passwordHash          String?                    @map("password_hash")
  role                  UserRole
  status                UserStatus                 @default(ACTIVE)
  avatarUrl             String?                    @map("avatar_url")
  fullName              String                     @map("full_name")
  country               String?
  timezone              String?
  language              String?                    @default("en")
  emailVerified         Boolean                    @default(false) @map("email_verified")
  emailVerifiedAt       DateTime?                  @map("email_verified_at")
  lastLoginAt           DateTime?                  @map("last_login_at")
  createdAt             DateTime                   @default(now()) @map("created_at")
  updatedAt             DateTime                   @updatedAt @map("updated_at")
  deletedAt             DateTime?                  @map("deleted_at")
  nickname              String?
  phone                 String?                    @unique
  languageCode          String                     @default("en") @map("language_code")
  activityLogs          ActivityLog[]
  authAuditLogs         AuthAuditLog[]
  aiCopilotContexts     AiCopilotContext[]
  aiPreference          AiPreference?
  brandProfile          BrandProfile?
  brandCampaigns        Campaign[]                 @relation("BrandCampaigns")
  creatorCampaigns      Campaign[]                 @relation("CreatorCampaigns")
  aiCopilotMessages     ChatMessage[]
  aiCopilotSessions     ChatSession[]
  receivedMessages      CommunicationMessage[]     @relation("ReceivedMessages")
  sentMessages          CommunicationMessage[]     @relation("SentMessages")
  assignedConversations Conversation[]             @relation("AssignedConversations")
  customerConversations Conversation[]             @relation("CustomerConversations")
  creatorEarnings       CreatorEarnings?
  membershipHistory     CreatorMembershipHistory[] @relation("CreatorMembershipHistory")
  creatorMemberships    CreatorMembership[]
  creatorProfile        CreatorProfile?
  notifications         Notification[]
  orderCommissions      OrderCommission[]          @relation("CreatorOrderCommissions")
  clientOrders          Order[]                    @relation("ClientOrders")
  creatorOrders         Order[]                    @relation("CreatorOrders")
  referredOrders        Order[]                    @relation("ReferredOrders")
  paymentMethods        PaymentMethod[]
  performanceSources    PerformanceSource[]
  referralCodes         ReferralCode[]
  referralCommissions   ReferralCommission[]       @relation("ReferralCommissions")
  referralsReceived     ReferralRelation?          @relation("ReferralsReceived")
  referralsMade         ReferralRelation[]         @relation("ReferralsMade")
  brandRelationships    RelationshipDna[]          @relation("BrandRelationships")
  creatorRelationships  RelationshipDna[]          @relation("CreatorRelationships")
  reviewComments        ReviewComment[]
  storageFiles          StorageFile[]
  studioProfile         StudioProfile?
  preferredLanguage     Language                   @relation(fields: [languageCode], references: [code])
  walletAccount         WalletAccount?
  wallet                Wallet?
  oauthAccounts         UserOAuthAccount[]
  campaignAiUsageLogs   CampaignAiUsageLog[]

  @@index([role])
  @@index([status])
  @@index([phone])
  @@index([languageCode])
  @@map("users")
}

model UserOAuthAccount {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  provider       String
  providerUserId String   @map("provider_user_id")
  createdAt      DateTime @default(now()) @map("created_at")
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@index([userId])
  @@map("user_oauth_accounts")
}

model AuthRateLimit {
  id          String   @id @default(uuid())
  key         String
  scope       String
  count       Int      @default(0)
  windowStart DateTime @map("window_start")
  expiresAt   DateTime @map("expires_at")

  @@unique([key, scope])
  @@index([expiresAt])
  @@map("auth_rate_limits")
}

model EmailVerificationCode {
  id            String                  @id @default(uuid())
  email         String
  codeHash      String                  @map("code_hash")
  purpose       AuthVerificationPurpose @default(SIGNUP_LOGIN)
  attempts      Int                     @default(0)
  maxAttempts   Int                     @default(5) @map("max_attempts")
  expiresAt     DateTime                @map("expires_at")
  consumedAt    DateTime?               @map("consumed_at")
  createdAt     DateTime                @default(now()) @map("created_at")
  ipHash        String?                 @map("ip_hash")
  userAgentHash String?                 @map("user_agent_hash")

  @@index([email, purpose, consumedAt])
  @@index([expiresAt])
  @@map("email_verification_codes")
}

model AuthAttempt {
  id            String          @id @default(uuid())
  emailHash     String?         @map("email_hash")
  ipHash        String?         @map("ip_hash")
  provider      String?
  type          AuthAttemptType
  success       Boolean
  failureReason String?         @map("failure_reason")
  createdAt     DateTime        @default(now()) @map("created_at")

  @@index([emailHash, type, createdAt])
  @@index([ipHash, type, createdAt])
  @@index([provider, createdAt])
  @@map("auth_attempts")
}

model AuthLock {
  id          String   @id @default(uuid())
  emailHash   String?  @map("email_hash")
  ipHash      String?  @map("ip_hash")
  reason      String
  lockedUntil DateTime @map("locked_until")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([emailHash, lockedUntil])
  @@index([ipHash, lockedUntil])
  @@map("auth_locks")
}

model AuthAuditLog {
  id            String         @id @default(uuid())
  userId        String?        @map("user_id")
  emailHash     String?        @map("email_hash")
  event         AuthAuditEvent
  ipHash        String?        @map("ip_hash")
  userAgentHash String?        @map("user_agent_hash")
  metadata      Json?
  createdAt     DateTime       @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([emailHash, createdAt])
  @@index([event, createdAt])
  @@map("auth_audit_logs")
}

enum AdminAccountStatus {
  PENDING_TOTP
  ACTIVE
  SUSPENDED
  LOCKED
}

model AdminUser {
  id                  String                    @id @default(uuid())
  email               String                    @unique
  fullName            String                    @map("full_name")
  isMaster            Boolean                   @default(false) @map("is_master")
  status              AdminAccountStatus        @default(PENDING_TOTP)
  totpSecretEnc       String?                   @map("totp_secret_enc")
  totpEnabled         Boolean                   @default(false) @map("totp_enabled")
  totpBoundAt         DateTime?                 @map("totp_bound_at")
  lastVerifiedAt      DateTime?                 @map("last_verified_at")
  failedAttempts      Int                       @default(0) @map("failed_attempts")
  lockedUntil         DateTime?                 @map("locked_until")
  permissions         Json?
  deletedAt           DateTime?                 @map("deleted_at")
  createdAt           DateTime                  @default(now()) @map("created_at")
  updatedAt           DateTime                  @updatedAt @map("updated_at")
  sessions            AdminSession[]
  auditLogs           AdminAuthAuditLog[]
  webAuthnCredentials AdminWebAuthnCredential[]
  totpConsumptions    AdminTotpConsumption[]

  @@index([status, totpEnabled])
  @@index([isMaster])
  @@map("admin_users")
}

model AdminWebAuthnCredential {
  id           String    @id @default(uuid())
  adminUserId  String    @map("admin_user_id")
  credentialId String    @unique @map("credential_id")
  publicKey    Bytes     @map("public_key")
  counter      BigInt    @default(0)
  deviceType   String?   @map("device_type")
  backedUp     Boolean   @default(false) @map("backed_up")
  transports   String?
  label        String?
  createdAt    DateTime  @default(now()) @map("created_at")
  lastUsedAt   DateTime? @map("last_used_at")
  adminUser    AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)

  @@index([adminUserId])
  @@map("admin_webauthn_credentials")
}

model AdminTotpConsumption {
  id          String    @id @default(uuid())
  adminUserId String    @map("admin_user_id")
  timeStep    Int       @map("time_step")
  codeHash    String    @map("code_hash")
  purpose     String
  expiresAt   DateTime  @map("expires_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  adminUser   AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)

  @@unique([adminUserId, timeStep, codeHash])
  @@index([expiresAt])
  @@map("admin_totp_consumptions")
}

model AdminSession {
  id            String    @id @default(uuid())
  adminUserId   String    @map("admin_user_id")
  tokenHash     String    @unique @map("token_hash")
  ipHash        String    @map("ip_hash")
  userAgentHash String    @map("user_agent_hash")
  deviceLabel   String?   @map("device_label")
  lastActiveAt  DateTime? @map("last_active_at")
  expiresAt     DateTime  @map("expires_at")
  revokedAt     DateTime? @map("revoked_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  adminUser     AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)

  @@index([adminUserId, expiresAt])
  @@index([expiresAt])
  @@map("admin_sessions")
}

model AdminAuthAuditLog {
  id            String     @id @default(uuid())
  adminUserId   String?    @map("admin_user_id")
  emailHash     String     @map("email_hash")
  ipHash        String     @map("ip_hash")
  userAgentHash String     @map("user_agent_hash")
  event         String
  success       Boolean
  failureReason String?    @map("failure_reason")
  metadata      Json?
  createdAt     DateTime   @default(now()) @map("created_at")
  adminUser     AdminUser? @relation(fields: [adminUserId], references: [id], onDelete: SetNull)

  @@index([adminUserId, createdAt])
  @@index([emailHash, createdAt])
  @@index([ipHash, createdAt])
  @@index([event, createdAt])
  @@map("admin_audit_logs")
}

model Language {
  id           String                @id @default(uuid())
  code         String                @unique
  locale       String                @unique
  nativeName   String                @map("native_name")
  englishName  String                @map("english_name")
  isDefault    Boolean               @default(false) @map("is_default")
  isEnabled    Boolean               @default(true) @map("is_enabled")
  sortOrder    Int                   @default(0) @map("sort_order")
  createdAt    DateTime              @default(now()) @map("created_at")
  updatedAt    DateTime              @updatedAt @map("updated_at")
  translations LanguageTranslation[]
  users        User[]

  @@index([isEnabled, sortOrder])
  @@map("languages")
}

model LanguageKey {
  id           String                @id @default(uuid())
  namespace    String
  key          String
  description  String?
  createdAt    DateTime              @default(now()) @map("created_at")
  updatedAt    DateTime              @updatedAt @map("updated_at")
  translations LanguageTranslation[]

  @@unique([namespace, key])
  @@index([namespace])
  @@map("language_keys")
}

model LanguageTranslation {
  id           String      @id @default(uuid())
  keyId        String      @map("key_id")
  languageCode String      @map("language_code")
  value        String
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")
  key          LanguageKey @relation(fields: [keyId], references: [id], onDelete: Cascade)
  language     Language    @relation(fields: [languageCode], references: [code], onDelete: Cascade)

  @@unique([keyId, languageCode])
  @@index([languageCode])
  @@map("language_translations")
}

model ChatSession {
  id        String             @id @default(uuid())
  userId    String             @map("user_id")
  role      String
  title     String?
  status    String             @default("OPEN")
  createdAt DateTime           @default(now()) @map("created_at")
  updatedAt DateTime           @updatedAt @map("updated_at")
  contexts  AiCopilotContext[]
  toolCalls AiToolCall[]
  messages  ChatMessage[]
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, updatedAt])
  @@index([status])
  @@map("chat_sessions")
}

model ChatMessage {
  id           String       @id @default(uuid())
  sessionId    String       @map("session_id")
  userId       String?      @map("user_id")
  role         String
  content      String
  metadataJson Json?        @map("metadata_json")
  createdAt    DateTime     @default(now()) @map("created_at")
  toolCalls    AiToolCall[]
  session      ChatSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id])

  @@index([sessionId, createdAt])
  @@index([userId])
  @@map("chat_messages")
}

model AiToolCall {
  id         String       @id @default(uuid())
  sessionId  String       @map("session_id")
  messageId  String?      @map("message_id")
  toolName   String       @map("tool_name")
  inputJson  Json?        @map("input_json")
  outputJson Json?        @map("output_json")
  status     String       @default("SUCCESS")
  durationMs Int?         @map("duration_ms")
  createdAt  DateTime     @default(now()) @map("created_at")
  message    ChatMessage? @relation(fields: [messageId], references: [id])
  session    ChatSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
  @@index([messageId])
  @@index([toolName])
  @@map("ai_tool_calls")
}

model AiCopilotContext {
  id          String      @id @default(uuid())
  sessionId   String      @map("session_id")
  userId      String      @map("user_id")
  role        String
  pagePath    String?     @map("page_path")
  entityType  String?     @map("entity_type")
  entityId    String?     @map("entity_id")
  contextJson Json        @map("context_json")
  createdAt   DateTime    @default(now()) @map("created_at")
  session     ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
  @@index([userId])
  @@index([entityType, entityId])
  @@map("ai_copilot_contexts")
}

model AiKnowledgeQa {
  id              String    @id @default(uuid())
  campaignId      String?   @map("campaign_id")
  sourceKey       String    @unique @map("source_key")
  languageCode    String    @map("language_code")
  module          String?
  question        String
  answer          String
  searchText      String    @map("search_text")
  knowledgeType   String    @default("FAQ") @map("knowledge_type")
  visibility      String    @default("authenticated") @map("visibility")
  sourceType      String    @default("unknown") @map("source_type")
  version         String?   @map("version")
  verifiedAt      DateTime? @map("verified_at")
  status          String    @default("ACTIVE")
  usageCount      Int       @default(0) @map("usage_count")
  helpfulCount    Int       @default(0) @map("helpful_count")
  notHelpfulCount Int       @default(0) @map("not_helpful_count")
  metadataJson    Json?     @map("metadata_json")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  campaign        Campaign? @relation(fields: [campaignId], references: [id])

  @@index([campaignId])
  @@index([languageCode])
  @@index([status])
  @@index([usageCount])
  @@index([languageCode, status, knowledgeType, visibility, sourceType])
  @@map("ai_knowledge_qas")
}

model BrandProfile {
  id                 String   @id @default(uuid())
  userId             String   @unique @map("user_id")
  companyName        String   @map("company_name")
  website            String?
  logoUrl            String?  @map("logo_url")
  industry           String?
  brandDescription   String?  @map("brand_description")
  creditScore        Int      @default(100) @map("credit_score")
  completedCampaigns Int      @default(0) @map("completed_campaigns")
  brandDnaJson       Json?    @map("brand_dna_json")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")
  user               User     @relation(fields: [userId], references: [id])

  @@map("brand_profiles")
}

model StudioProfile {
  id          String              @id @default(uuid())
  userId      String              @unique @map("user_id")
  studioName  String              @map("studio_name")
  companyName String              @map("company_name")
  website     String?
  logoUrl     String?             @map("logo_url")
  coverUrl    String?             @map("cover_url")
  country     String?
  city        String?
  description String?
  verified    Boolean             @default(false)
  rating      Decimal?            @db.Decimal(3, 2)
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")
  invitations CreatorInvitation[]
  creators    CreatorProfile[]
  user        User                @relation(fields: [userId], references: [id])

  @@map("studio_profiles")
}

model CreatorProfile {
  id                   String                 @id @default(uuid())
  userId               String                 @unique @map("user_id")
  displayName          String                 @map("display_name")
  headline             String?
  bio                  String?
  country              String?
  languagesJson        Json?                  @map("languages_json")
  availability         CreatorAvailability    @default(AVAILABLE)
  hourlyRate           Decimal?               @map("hourly_rate") @db.Decimal(18, 2)
  minBudget            Decimal?               @map("min_budget") @db.Decimal(18, 2)
  maxBudget            Decimal?               @map("max_budget") @db.Decimal(18, 2)
  creditScore          Int                    @default(100) @map("credit_score")
  aiQualityScore       Int                    @default(80) @map("ai_quality_score")
  completionRate       Decimal                @default(100) @map("completion_rate") @db.Decimal(5, 2)
  averageReviewRound   Decimal                @default(1) @map("average_review_round") @db.Decimal(5, 2)
  averageDeliveryDays  Decimal                @default(5) @map("average_delivery_days") @db.Decimal(5, 2)
  completedCampaigns   Int                    @default(0) @map("completed_campaigns")
  creatorDnaJson       Json?                  @map("creator_dna_json")
  portfolioCover       String?                @map("portfolio_cover")
  createdAt            DateTime               @default(now()) @map("created_at")
  updatedAt            DateTime               @updatedAt @map("updated_at")
  studioId             String?                @map("studio_id")
  city                 String?
  serviceCitiesJson    Json?                  @map("service_cities_json")
  socialLinksJson      Json?                  @map("social_links_json")
  stylesJson           Json?                  @map("styles_json")
  specialtiesJson      Json?                  @map("specialties_json")
  toolsJson            Json?                  @map("tools_json")
  expertiseDomainsJson Json?                  @map("expertise_domains_json")
  portfolioUrl         String?                @map("portfolio_url")
  aiEnabled            Boolean                @default(true) @map("ai_enabled")
  profileCompletedAt   DateTime?              @map("profile_completed_at")
  legacyCreatorId      String?                @unique @map("legacy_creator_id")
  attributions         Attribution[]
  connectedChannels    ConnectedChannel[]
  conversations        Conversation[]
  aiConfig             CreatorAiConfig?
  invitations          CreatorInvitation[]
  memberships          CreatorMembership[]
  portfolioWorks       CreatorPortfolioWork[]
  studio               StudioProfile?         @relation(fields: [studioId], references: [id])
  user                 User                   @relation(fields: [userId], references: [id])
  orders               Order[]

  @@index([studioId])
  @@index([country])
  @@index([availability])
  @@index([profileCompletedAt])
  @@map("creator_profiles")
}

model CreatorPortfolioWork {
  id           String         @id @default(uuid())
  creatorId    String         @map("creator_id")
  campaignId   String?        @map("campaign_id")
  title        String
  description  String?
  city         String?
  country      String?
  category     String?
  platform     String?
  format       String?
  workType     String?        @map("work_type")
  thumbnailUrl String?        @map("thumbnail_url")
  thumbnailKey String?        @map("thumbnail_key")
  videoUrl     String?        @map("video_url")
  videoKey     String?        @map("video_key")
  tagsJson     Json?          @map("tags_json")
  priceMin     Decimal?       @map("price_min") @db.Decimal(18, 2)
  priceMax     Decimal?       @map("price_max") @db.Decimal(18, 2)
  priceVisible Boolean        @default(false) @map("price_visible")
  isPublic     Boolean        @default(true) @map("is_public")
  sortOrder    Int            @default(0) @map("sort_order")
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")
  deletedAt    DateTime?      @map("deleted_at")
  campaign     Campaign?      @relation(fields: [campaignId], references: [id])
  creator      CreatorProfile @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  storageFiles StorageFile[]

  @@index([creatorId])
  @@index([campaignId])
  @@index([creatorId, isPublic, sortOrder])
  @@index([deletedAt])
  @@map("creator_portfolio_works")
}

model MarketingShowcaseWork {
  id                 String    @id @default(uuid())
  title              String
  description        String?
  category           String?
  platform           String?
  format             String?
  thumbnailUrl       String?   @map("thumbnail_url")
  thumbnailKey       String?   @map("thumbnail_key")
  videoUrl           String?   @map("video_url")
  videoKey           String?   @map("video_key")
  tagsJson           Json?     @map("tags_json")
  isPublished        Boolean   @default(true) @map("is_published")
  featuredOnHomepage Boolean   @default(false) @map("featured_on_homepage")
  homepageSortOrder  Int       @default(0) @map("homepage_sort_order")
  sortOrder          Int       @default(0) @map("sort_order")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")
  deletedAt          DateTime? @map("deleted_at")

  @@index([isPublished, featuredOnHomepage, homepageSortOrder])
  @@index([category])
  @@index([deletedAt])
  @@map("marketing_showcase_works")
}

model CreatorAiConfig {
  id                 String         @id @default(uuid())
  creatorId          String         @unique @map("creator_id")
  aiName             String         @map("ai_name")
  persona            String?
  welcomeMessage     String?        @map("welcome_message")
  serviceIntro       String?        @map("service_intro")
  faqJson            Json?          @map("faq_json")
  pricingRulesJson   Json?          @map("pricing_rules_json")
  receptionScript    String?        @map("reception_script")
  multilingualJson   Json?          @map("multilingual_json")
  defaultReply       String?        @map("default_reply")
  blockedContentJson Json?          @map("blocked_content_json")
  handoffRulesJson   Json?          @map("handoff_rules_json")
  dataSourcesJson    Json?          @map("data_sources_json")
  isEnabled          Boolean        @default(true) @map("is_enabled")
  createdAt          DateTime       @default(now()) @map("created_at")
  updatedAt          DateTime       @updatedAt @map("updated_at")
  creator            CreatorProfile @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  @@map("creator_ai_configs")
}

model ConnectedChannel {
  id                String         @id @default(uuid())
  creatorId         String         @map("creator_id")
  platform          String
  accountUrl        String?        @map("account_url")
  accountHandle     String?        @map("account_handle")
  status            String         @default("DISCONNECTED")
  sourceCount       Int            @default(0) @map("source_count")
  aiLearningEnabled Boolean        @default(true) @map("ai_learning_enabled")
  metadataJson      Json?          @map("metadata_json")
  lastSyncedAt      DateTime?      @map("last_synced_at")
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")
  creator           CreatorProfile @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  @@unique([creatorId, platform])
  @@index([creatorId])
  @@index([platform])
  @@index([status])
  @@index([aiLearningEnabled])
  @@map("connected_channels")
}

model Campaign {
  id                        String                 @id @default(uuid())
  brandId                   String                 @map("brand_id")
  creatorId                 String?                @map("creator_id")
  title                     String
  description               String?
  budget                    Decimal                @db.Decimal(18, 2)
  currency                  String                 @default("USD")
  deadline                  DateTime
  platform                  String?
  aspectRatio               String?                @map("aspect_ratio")
  status                    CampaignStatus         @default(DRAFT)
  creativeDirection         String?                @map("creative_direction")
  productionBrief           Json?                  @map("production_brief")
  campaignMemoryJson        Json?                  @map("campaign_memory_json")
  campaignHealth            Int                    @default(100) @map("campaign_health")
  reviewRound               Int                    @default(0) @map("review_round")
  currentVersion            Int                    @default(0) @map("current_version")
  createdBy                 String?                @map("created_by")
  createdAt                 DateTime               @default(now()) @map("created_at")
  updatedAt                 DateTime               @updatedAt @map("updated_at")
  deletedAt                 DateTime?              @map("deleted_at")
  paidRevisionSlotsUnlocked Int                    @default(0) @map("paid_revision_slots_unlocked")
  academyCourses            AcademyCourse[]
  activities                ActivityLog[]
