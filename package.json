{
  "name": "adbridge",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20 <23"
  },
  "scripts": {
    "dev": "bash scripts/free-dev-ports.sh && node scripts/copy-marketing-assets.mjs && next dev -p 3000",
    "dev:quick": "bash scripts/free-dev-ports.sh && next dev -p 3000",
    "dev:local": "bash scripts/dev-local.sh",
    "dev:clean": "bash scripts/free-dev-ports.sh && node scripts/copy-marketing-assets.mjs && rm -rf .next && next dev -p 3000",
    "dev:kill": "bash scripts/free-dev-ports.sh",
    "dev:reset": "rm -rf .next node_modules/.cache && npm run dev",
    "dev:fix": "bash scripts/dev-local.sh",
    "reset:demo-review": "node scripts/reset-mvp-demo.mjs",
    "build": "npx prisma generate && node scripts/copy-marketing-assets.mjs && next build",
    "postinstall": "npx prisma generate",
    "start": "next start",
    "lint": "next lint --no-cache",
    "typecheck": "tsc --noEmit",
    "verify": "npm run typecheck",
    "deploy": "bash scripts/deploy-fast.sh",
    "deploy:vercel-only": "npx vercel --prod --yes",
    "install:hero-bg": "node scripts/copy-marketing-assets.mjs",
    "db:generate": "npx prisma generate",
    "db:migrate": "npx prisma migrate dev",
    "db:migrate:deploy": "npx prisma migrate deploy",
