{
  "name": "adbridge",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/copy-marketing-assets.mjs && next dev -p 3000",
    "dev:clean": "node scripts/copy-marketing-assets.mjs && rm -rf .next && next dev -p 3000",
    "dev:3001": "node scripts/copy-marketing-assets.mjs && next dev -p 3001",
    "dev:reset": "rm -rf .next node_modules/.cache && next dev -p 3000",
    "build": "node scripts/copy-marketing-assets.mjs && next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.3",
    "@supabase/ssr": "^0.7.0",
    "@supabase/supabase-js": "^2.51.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "next": "^15.3.4",
    "resend": "^4.6.0",
    "stripe": "^17.7.0",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.7.2",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.3.4",
    "postcss": "^8.4.49",
    "prettier": "^3.4.2",
    "tailwindcss": "^3.4.17"
  }
}
