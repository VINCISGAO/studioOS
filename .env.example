# --- Auth (Google OAuth via Supabase) ---
# 1. Create a project at https://supabase.com
# 2. Dashboard → Authentication → Providers → Google → paste Client ID + Secret
# 3. Google Cloud Console → OAuth client → Authorized redirect URI:
#    https://<your-project-ref>.supabase.co/auth/v1/callback
# 4. Supabase → Authentication → URL Configuration:
#    Site URL: http://localhost:3000 (or production domain)
#    Redirect URLs: http://localhost:3000/auth/callback
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# App origin used for OAuth callback (must match Site URL host)
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Set to 1 to use Supabase session instead of demo auth cookie
STUDIOOS_FORCE_SUPABASE_AUTH=1

STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
# Email verification codes (Resend) — https://resend.com
RESEND_API_KEY=
AUTH_EMAIL_FROM="StudioOS <onboarding@resend.dev>"
RESEND_FROM_EMAIL="StudioOS <orders@studioos.ai>"

# PostgreSQL (Prisma) — docker compose up -d
DATABASE_URL=postgresql://studioos:studioos@localhost:5432/studioos
# Optional: unpooled URL for `prisma migrate` (Neon: omit `-pooler` from host). Auto-derived if unset.
# DIRECT_DATABASE_URL=
# migrate-deploy.sh defaults PRISMA_SCHEMA_DISABLE_ADVISORY_LOCK=1 (Neon P1002). Set 0 to re-enable:
# PRISMA_SCHEMA_DISABLE_ADVISORY_LOCK=0

# Redis (BullMQ workers — Phase 6+)
REDIS_URL=redis://localhost:6379

# Object storage — MinIO local dev (Phase 6+)
R2_ENDPOINT=http://localhost:9000
R2_ACCESS_KEY=studioos
R2_SECRET_KEY=studioosdev
R2_BUCKET=studioos

# Step 1 — Production Copilot (OpenAI)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_VISION_MODEL=gpt-4o
OPENAI_IMAGE_MODEL=gpt-image-1

# Step 3 — Creative Analytics (optional live ad data)
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=
TIKTOK_ACCESS_TOKEN=
TIKTOK_ADVERTISER_ID=

# Video Engine — Phase 6 (Vol 06)
VIDEO_WORKER_MODE=simulate
VIDEO_ENFORCE_HLS=1
PLAYBACK_SIGNING_SECRET=studioos-dev-playback-signing-secret
PLAYBACK_TOKEN_TTL_SEC=3600
VIDEO_WATERMARK_TEXT=StudioOS Preview

# Backup & disaster recovery — scripts/backup/
# Local backup root (default: ~/StudioOS-Backups)
BACKUP_ROOT=
BACKUP_PROJECT_NAME=StudioOS
BACKUP_RETENTION_COUNT=30
# S3-compatible cloud upload (AWS S3, Cloudflare R2, MinIO)
BACKUP_CLOUD_ENABLED=0
BACKUP_S3_ENDPOINT=
BACKUP_S3_REGION=auto
BACKUP_S3_BUCKET=
BACKUP_S3_ACCESS_KEY=
BACKUP_S3_SECRET_KEY=
BACKUP_S3_PROJECT_PREFIX=backups/project/
BACKUP_S3_DATABASE_PREFIX=backups/database/

# Step 2 — set to 1 to skip ffprobe even if installed
STUDIOOS_DISABLE_FFPROBE=

# Monitoring — Sprint 18 (optional; enable flag in admin + set DSN)
SENTRY_DSN=

FRAME_IO_CLIENT_ID=
FRAME_IO_CLIENT_SECRET=
FRAME_IO_ACCOUNT_ID=
FRAME_IO_WORKSPACE_ID=
FRAME_IO_WEBHOOK_SECRET=
FRAME_IO_API_BASE=https://api.frame.io
