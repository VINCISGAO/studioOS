NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
RESEND_API_KEY=
RESEND_FROM_EMAIL=AdBridge <orders@adbridge.ai>
NEXT_PUBLIC_APP_URL=http://localhost:3000

# PostgreSQL (Prisma) — docker compose up -d
DATABASE_URL=postgresql://studioos:studioos@localhost:5432/studioos

# Redis (BullMQ workers — Phase 6+)
REDIS_URL=redis://localhost:6379

# Object storage — MinIO local dev (Phase 6+)
R2_ENDPOINT=http://localhost:9000
R2_ACCESS_KEY=studioos
R2_SECRET_KEY=studioosdev
R2_BUCKET=studioos

# Step 1 — Production Copilot (OpenAI)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_VISION_MODEL=gpt-4o
OPENAI_IMAGE_MODEL=gpt-image-1

# Step 3 — Creative Analytics (optional live ad data)
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=
TIKTOK_ACCESS_TOKEN=
TIKTOK_ADVERTISER_ID=

# Video Engine — Phase 6 (Vol 06)
VIDEO_WORKER_MODE=simulate
VIDEO_ENFORCE_HLS=1
PLAYBACK_SIGNING_SECRET=studioos-dev-playback-signing-secret
PLAYBACK_TOKEN_TTL_SEC=3600
VIDEO_WATERMARK_TEXT=StudioOS Preview

# Backup & disaster recovery — scripts/backup/
# Local backup root (default: ~/StudioOS-Backups)
BACKUP_ROOT=
BACKUP_PROJECT_NAME=StudioOS
BACKUP_RETENTION_COUNT=30
# S3-compatible cloud upload (AWS S3, Cloudflare R2, MinIO)
BACKUP_CLOUD_ENABLED=0
BACKUP_S3_ENDPOINT=
BACKUP_S3_REGION=auto
BACKUP_S3_BUCKET=
BACKUP_S3_ACCESS_KEY=
BACKUP_S3_SECRET_KEY=
BACKUP_S3_PROJECT_PREFIX=backups/project/
BACKUP_S3_DATABASE_PREFIX=backups/database/

# Step 2 — set to 1 to skip ffprobe even if installed
STUDIOOS_DISABLE_FFPROBE=

# Review Engine — Frame.io external review (v1)
FRAME_IO_CLIENT_ID=
FRAME_IO_CLIENT_SECRET=
FRAME_IO_ACCOUNT_ID=
FRAME_IO_WORKSPACE_ID=
FRAME_IO_WEBHOOK_SECRET=
FRAME_IO_API_BASE=https://api.frame.io
